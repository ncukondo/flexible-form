{
  "permissions": {
    "allow": [
      "Bash(tmux:*)",
      "Bash(which:*)",
      "Bash(sleep:*)",
      "Read(/workspaces/flexible-form--worktrees/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/flexible-form/.claude/hooks/block-force-push.sh"
          }
        ]
      }
    ]
  }
}
